{
	"name": "api",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc && esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --alias:@shelf/db=../../packages/db/src/index.ts --alias:@shelf/shared=../../packages/shared/src/index.ts --outfile=dist/index.js",
		"start": "node dist/index.js"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.9",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^1.5.1",
		"@shelf/db": "workspace:*",
		"@shelf/shared": "workspace:*",
		"better-sqlite3": "^12.11.1",
		"cheerio": "^1.2.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.30",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@hono/zod-validator": "^0.9.0",
		"@types/node": "^26.1.1",
		"esbuild": "^0.28.1",
		"tsx": "^4.23.0",
		"typescript": "^7.0.2"
	}
}
