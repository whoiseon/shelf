{
	"name": "api",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc && esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
		"start": "node dist/index.js"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.9",
		"dotenv": "^17.4.2",
		"hono": "^4.12.30"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"esbuild": "^0.28.1",
		"tsx": "^4.23.0",
		"typescript": "^7.0.2"
	}
}
